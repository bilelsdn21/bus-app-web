# Copy to .env (local) or set these in Render (production).

# Database — local SQLite by default; production = Supabase Postgres URI
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.XXXX.supabase.co:5432/postgres?sslmode=require

# Two users (override the defaults admin/btt2026, terrain/terrain2026)
BUS_USERS=admin:btt2026,terrain:terrain2026

# Secret used to sign login tokens — set a long random string in production
BUS_SECRET=change-me-to-a-long-random-string

# Allowed frontend origin(s) for CORS — your Vercel URL in production
# CORS_ORIGINS=https://your-app.vercel.app
